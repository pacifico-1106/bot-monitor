<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tokyo307.healthagent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/YOUR_USERNAME/health_agent.py</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>DASHBOARD_API_URL</key>
        <string>https://your-vercel-app.vercel.app/api/health</string>
        <key>HEALTH_API_KEY</key>
        <string>your-secret-api-key</string>
        <key>MACHINE_ID</key>
        <string>mac-mini-1</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/YOUR_USERNAME/Library/Logs/health_agent.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USERNAME/Library/Logs/health_agent_error.log</string>
</dict>
</plist>
