# Bot Monitor - Environment Variables Template
#
# このファイルは公開リポジトリに含まれます
# 実際の値は Vercel のダッシュボードで設定してください
#
# Vercel Dashboard > Settings > Environment Variables

# API Key for health agent authentication
# ヘルスエージェントからのデータ送信時の認証キー
# 推奨: ランダムな32文字以上の文字列（例: openssl rand -hex 32）
HEALTH_API_KEY=your-secret-api-key-here

# Dashboard Basic Authentication
# ダッシュボードへのアクセス制御用
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-secure-password-here
